{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://RayaTrainer.local/direct-gameapi/apis.schema.json",
  "title": "Direct GameApi catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "apis"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "const": 3
    },
    "apis": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "implementation",
          "requestType",
          "payloadType",
          "pipeCommand",
          "requestFields",
          "payloadFields",
          "featureMethod"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "implementation": {
            "const": "native"
          },
          "requestType": {
            "type": "string",
            "minLength": 1
          },
          "payloadType": {
            "type": "string",
            "minLength": 1
          },
          "pipeCommand": {
            "$ref": "#/$defs/pipeCommand"
          },
          "requestFields": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/field"
            }
          },
          "payloadFields": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/field"
            }
          },
          "featureMethod": {
            "$ref": "#/$defs/featureMethod"
          }
        }
      }
    }
  },
  "$defs": {
    "pipeCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "value",
        "clientMethod"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "clientMethod": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "requiredNonZero": {
          "type": "boolean"
        }
      }
    },
    "featureMethod": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "returnType",
        "parameters"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "returnType": {
          "type": "string",
          "minLength": 1
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/featureParameter"
          }
        },
        "returnField": {
          "type": [
            "string",
            "null"
          ]
        },
        "docSummary": {
          "type": [
            "string",
            "null"
          ]
        },
        "docReturn": {
          "type": [
            "string",
            "null"
          ]
        },
        "generate": {
          "type": "boolean"
        }
      }
    },
    "featureParameter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "mapsTo": {
          "type": [
            "string",
            "null"
          ]
        },
        "default": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
