<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Surface -->
  <Color x:Key="ColorWindowBackground">#0F1117</Color>
  <Color x:Key="ColorSidebarBackground">#161B22</Color>
  <Color x:Key="ColorCardBackground">#1C2333</Color>
  <Color x:Key="ColorCardBorder">#2D3548</Color>
  <Color x:Key="ColorInputBackground">#0D1117</Color>
  <Color x:Key="ColorInputBorder">#30363D</Color>
  <Color x:Key="ColorToolbarBackground">#161B22</Color>
  <Color x:Key="ColorHoverBackground">#1F2A3A</Color>
  <Color x:Key="ColorSelectedBackground">#1F2A3A</Color>

  <!-- Accent (Allied 蓝 = 主操作/常规) -->
  <Color x:Key="ColorPrimary">#4FA8E0</Color>
  <Color x:Key="ColorPrimaryHover">#3B95CF</Color>
  <Color x:Key="ColorAccent">#4FA8E0</Color>
  <Color x:Key="ColorSuccess">#36C46B</Color>
  <Color x:Key="ColorWarning">#E8B84B</Color>
  <Color x:Key="ColorError">#E2533A</Color>

  <!-- Faction 语义色 (苏红=破坏性 / 旭日=计数；盟蓝=Primary 复用) -->
  <Color x:Key="ColorFactionSoviet">#E2533A</Color>
  <Color x:Key="ColorFactionImperial">#E8B84B</Color>
  <!-- Soft 变体用于 chip 浅底 (16% 不透明叠在 panel 上) -->
  <Color x:Key="ColorFactionSovietSoft">#3A1A14</Color>
  <Color x:Key="ColorFactionAlliedSoft">#0F2433</Color>
  <Color x:Key="ColorFactionImperialSoft">#332A12</Color>

  <!-- Text -->
  <Color x:Key="ColorTextPrimary">#E6EDF3</Color>
  <Color x:Key="ColorTextSecondary">#9CA3AF</Color>
  <Color x:Key="ColorTextDim">#8B949E</Color>
  <Color x:Key="ColorTextDisabled">#5C6370</Color>

  <!-- Buttons -->
  <Color x:Key="ColorButtonBackground">#21262D</Color>
  <Color x:Key="ColorButtonBorder">#30363D</Color>
  <Color x:Key="ColorButtonHoverBackground">#30363D</Color>
  <Color x:Key="ColorButtonPressedBackground">#161B22</Color>
  <Color x:Key="ColorButtonDisabledBackground">#161B22</Color>

  <!-- Toggle -->
  <Color x:Key="ColorToggleOffTrack">#4B5563</Color>
  <Color x:Key="ColorToggleOnTrack">#22C55E</Color>

  <!-- KeyBadge -->
  <Color x:Key="ColorKeyBadgeBackground">#21262D</Color>
  <Color x:Key="ColorKeyBadgeBorder">#30363D</Color>
  <Color x:Key="ColorKeyBadgeText">#9CA3AF</Color>

  <!-- ScrollBar -->
  <Color x:Key="ColorScrollBarBackground">#0F1117</Color>
  <Color x:Key="ColorScrollBarThumb">#30363D</Color>
  <Color x:Key="ColorScrollBarThumbHover">#484F58</Color>

  <!-- Brushes -->
  <SolidColorBrush x:Key="BrushWindowBackground" Color="{DynamicResource ColorWindowBackground}" />
  <SolidColorBrush x:Key="BrushSidebarBackground" Color="{DynamicResource ColorSidebarBackground}" />
  <SolidColorBrush x:Key="BrushCardBackground" Color="{DynamicResource ColorCardBackground}" />
  <SolidColorBrush x:Key="BrushCardBorder" Color="{DynamicResource ColorCardBorder}" />
  <SolidColorBrush x:Key="BrushInputBackground" Color="{DynamicResource ColorInputBackground}" />
  <SolidColorBrush x:Key="BrushInputBorder" Color="{DynamicResource ColorInputBorder}" />
  <SolidColorBrush x:Key="BrushToolbarBackground" Color="{DynamicResource ColorToolbarBackground}" />
  <SolidColorBrush x:Key="BrushHoverBackground" Color="{DynamicResource ColorHoverBackground}" />
  <SolidColorBrush x:Key="BrushSelectedBackground" Color="{DynamicResource ColorSelectedBackground}" />

  <SolidColorBrush x:Key="BrushPrimary" Color="{DynamicResource ColorPrimary}" />
  <SolidColorBrush x:Key="BrushPrimaryHover" Color="{DynamicResource ColorPrimaryHover}" />
  <SolidColorBrush x:Key="BrushAccent" Color="{DynamicResource ColorAccent}" />
  <SolidColorBrush x:Key="BrushSuccess" Color="{DynamicResource ColorSuccess}" />
  <SolidColorBrush x:Key="BrushWarning" Color="{DynamicResource ColorWarning}" />
  <SolidColorBrush x:Key="BrushError" Color="{DynamicResource ColorError}" />

  <SolidColorBrush x:Key="BrushFactionSoviet" Color="{DynamicResource ColorFactionSoviet}" />
  <SolidColorBrush x:Key="BrushFactionImperial" Color="{DynamicResource ColorFactionImperial}" />
  <SolidColorBrush x:Key="BrushFactionSovietSoft" Color="{DynamicResource ColorFactionSovietSoft}" />
  <SolidColorBrush x:Key="BrushFactionAlliedSoft" Color="{DynamicResource ColorFactionAlliedSoft}" />
  <SolidColorBrush x:Key="BrushFactionImperialSoft" Color="{DynamicResource ColorFactionImperialSoft}" />

  <SolidColorBrush x:Key="BrushTextPrimary" Color="{DynamicResource ColorTextPrimary}" />
  <SolidColorBrush x:Key="BrushTextSecondary" Color="{DynamicResource ColorTextSecondary}" />
  <SolidColorBrush x:Key="BrushTextDim" Color="{DynamicResource ColorTextDim}" />
  <SolidColorBrush x:Key="BrushTextDisabled" Color="{DynamicResource ColorTextDisabled}" />

  <SolidColorBrush x:Key="BrushButtonBackground" Color="{DynamicResource ColorButtonBackground}" />
  <SolidColorBrush x:Key="BrushButtonBorder" Color="{DynamicResource ColorButtonBorder}" />
  <SolidColorBrush x:Key="BrushButtonHoverBackground" Color="{DynamicResource ColorButtonHoverBackground}" />
  <SolidColorBrush x:Key="BrushButtonPressedBackground" Color="{DynamicResource ColorButtonPressedBackground}" />
  <SolidColorBrush x:Key="BrushButtonDisabledBackground" Color="{DynamicResource ColorButtonDisabledBackground}" />

  <SolidColorBrush x:Key="BrushToggleOffTrack" Color="{DynamicResource ColorToggleOffTrack}" />
  <SolidColorBrush x:Key="BrushToggleOnTrack" Color="{DynamicResource ColorToggleOnTrack}" />

  <SolidColorBrush x:Key="BrushKeyBadgeBackground" Color="{DynamicResource ColorKeyBadgeBackground}" />
  <SolidColorBrush x:Key="BrushKeyBadgeBorder" Color="{DynamicResource ColorKeyBadgeBorder}" />
  <SolidColorBrush x:Key="BrushKeyBadgeText" Color="{DynamicResource ColorKeyBadgeText}" />

  <SolidColorBrush x:Key="BrushScrollBarBackground" Color="{DynamicResource ColorScrollBarBackground}" />
  <SolidColorBrush x:Key="BrushScrollBarThumb" Color="{DynamicResource ColorScrollBarThumb}" />
  <SolidColorBrush x:Key="BrushScrollBarThumbHover" Color="{DynamicResource ColorScrollBarThumbHover}" />

  <!-- Sidebar-specific brushes -->
  <SolidColorBrush x:Key="BrushSidebarTextPrimary" Color="{DynamicResource ColorTextPrimary}" />
  <SolidColorBrush x:Key="BrushSidebarTextSecondary" Color="{DynamicResource ColorTextSecondary}" />
  <SolidColorBrush x:Key="BrushSidebarTextDim" Color="{DynamicResource ColorTextDim}" />
  <SolidColorBrush x:Key="BrushSidebarHoverBackground" Color="{DynamicResource ColorHoverBackground}" />
  <SolidColorBrush x:Key="BrushSidebarSelectedBackground" Color="{DynamicResource ColorSelectedBackground}" />
</ResourceDictionary>
