<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ctrl="clr-namespace:RayaTrainer.App.Controls">
  <ResourceDictionary.MergedDictionaries>
    <ResourceDictionary Source="Buttons.xaml" />
    <ResourceDictionary Source="Inputs.xaml" />
    <ResourceDictionary Source="Cards.xaml" />
    <ResourceDictionary Source="ScrollBar.xaml" />
    <ResourceDictionary Source="Sidebar.xaml" />
  </ResourceDictionary.MergedDictionaries>

  <!-- ToggleSwitch Template -->
  <Style TargetType="{x:Type ctrl:ToggleSwitch}">
    <Setter Property="Width" Value="44" />
    <Setter Property="Height" Value="24" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ctrl:ToggleSwitch}">
          <Border x:Name="Track"
                  Background="{DynamicResource BrushToggleOffTrack}"
                  CornerRadius="12"
                  SnapsToDevicePixels="True">
            <Border x:Name="Knob"
                    Width="20" Height="20"
                    Background="White"
                    CornerRadius="10"
                    Margin="2,2,0,2"
                    HorizontalAlignment="Left"
                    SnapsToDevicePixels="True"
                    RenderTransformOrigin="0.5,0.5">
              <Border.RenderTransform>
                <TranslateTransform x:Name="KnobTransform" X="0" />
              </Border.RenderTransform>
            </Border>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="Track" Property="Background" Value="{DynamicResource BrushToggleOnTrack}" />
              <Setter TargetName="Knob" Property="Margin" Value="0,2,2,2" />
              <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.5" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- KeyBadge Template -->
  <Style TargetType="{x:Type ctrl:KeyBadge}">
    <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, Courier New" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Foreground" Value="{DynamicResource BrushKeyBadgeText}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ctrl:KeyBadge}">
          <Border Background="{DynamicResource BrushKeyBadgeBackground}"
                  BorderBrush="{DynamicResource BrushKeyBadgeBorder}"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="6,3"
                  SnapsToDevicePixels="True">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- HotkeyCaptureControl Template -->
  <Style TargetType="{x:Type ctrl:HotkeyCaptureControl}">
    <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, Courier New" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="MinWidth" Value="72" />
    <Setter Property="MinHeight" Value="26" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ctrl:HotkeyCaptureControl}">
          <Border x:Name="Badge"
                  Background="{DynamicResource BrushKeyBadgeBackground}"
                  BorderBrush="{DynamicResource BrushKeyBadgeBorder}"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="8,3"
                  SnapsToDevicePixels="True">
            <Grid>
              <!-- 已分配的热键文本 -->
              <TextBlock x:Name="HotkeyText"
                         Text="{TemplateBinding HotkeyText}"
                         Foreground="{DynamicResource BrushKeyBadgeText}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         Visibility="Collapsed" />
              <!-- 无热键时的占位 -->
              <TextBlock x:Name="PlaceholderText"
                         Text="{TemplateBinding Placeholder}"
                         Foreground="{DynamicResource BrushTextDim}"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
              <!-- 捕获态提示 -->
              <TextBlock x:Name="CapturingText"
                         Text="按下组合键…"
                         Foreground="{DynamicResource BrushPrimary}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         Visibility="Collapsed" />
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <!-- 已分配热键：显示键文本，隐藏占位 -->
            <Trigger Property="HasHotkey" Value="True">
              <Setter TargetName="HotkeyText" Property="Visibility" Value="Visible" />
              <Setter TargetName="PlaceholderText" Property="Visibility" Value="Collapsed" />
            </Trigger>
            <!-- 捕获态 -->
            <Trigger Property="IsCapturing" Value="True">
              <Setter TargetName="CapturingText" Property="Visibility" Value="Visible" />
              <Setter TargetName="HotkeyText" Property="Visibility" Value="Collapsed" />
              <Setter TargetName="PlaceholderText" Property="Visibility" Value="Collapsed" />
              <Setter TargetName="Badge" Property="BorderBrush" Value="{DynamicResource BrushPrimary}" />
              <Setter TargetName="Badge" Property="Background" Value="{DynamicResource BrushPrimaryHover}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ActionCard Template -->
  <Style TargetType="{x:Type ctrl:ActionCard}">
    <Setter Property="Background" Value="{DynamicResource BrushCardBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BrushCardBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Margin" Value="0,0,0,16" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ctrl:ActionCard}">
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="10"
                  Padding="20"
                  SnapsToDevicePixels="True">
            <StackPanel>
              <!-- Header (toggle button) -->
              <ToggleButton x:Name="ExpanderToggle"
                            IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                            Content="{TemplateBinding Header}"
                            Cursor="Hand"
                            Foreground="{DynamicResource BrushTextPrimary}"
                            FontWeight="SemiBold"
                            FontSize="14">
                <ToggleButton.Template>
                  <ControlTemplate TargetType="ToggleButton">
                    <Border Background="Transparent" Padding="0,4">
                      <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="Arrow"
                                   Text="&#9660;"
                                   FontSize="10"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Foreground="{DynamicResource BrushTextDim}" />
                        <ContentPresenter VerticalAlignment="Center" />
                      </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsChecked" Value="False">
                        <Setter TargetName="Arrow" Property="RenderTransform">
                          <Setter.Value>
                            <RotateTransform Angle="-90" />
                          </Setter.Value>
                        </Setter>
                        <Setter TargetName="Arrow" Property="RenderTransformOrigin" Value="0.5,0.5" />
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </ToggleButton.Template>
              </ToggleButton>
              <!-- Content -->
              <StackPanel x:Name="ContentPanel" Margin="0,12,0,0">
                <ContentPresenter />
              </StackPanel>
            </StackPanel>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsExpanded" Value="False">
              <Setter TargetName="ContentPanel" Property="Visibility" Value="Collapsed" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>
