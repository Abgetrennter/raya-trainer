<UserControl x:Class="RayaTrainer.App.Pages.HotkeySettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:RayaTrainer.App.Controls">
  <Grid Margin="0,0,0,16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- 顶部说明 -->
    <Border Grid.Row="0" Style="{DynamicResource ActionCardBorder}">
      <StackPanel>
        <TextBlock Text="快捷键设置" FontSize="14" FontWeight="SemiBold"
                   Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,8" />
        <TextBlock Foreground="{DynamicResource BrushTextSecondary}" FontSize="12" TextWrapping="Wrap">
          点击右侧按键徽章即可修改：进入捕获态后按下新的组合键（Esc 取消）。
          不需要的功能点击「清除」按钮即可置空。改完点击下方「保存」立即生效，无需重启。
          冲突时无法保存。仅在游戏窗口前台时热键才会触发。
        </TextBlock>
      </StackPanel>
    </Border>

    <!-- 分组列表 -->
    <Border Grid.Row="1" Style="{DynamicResource ActionCardBorder}" Margin="0,12,0,0">
      <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding Groups}" Background="Transparent" BorderThickness="0">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <StackPanel Margin="0,0,0,16">
                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource BrushTextPrimary}" Margin="0,4,0,8" />
                <ItemsControl ItemsSource="{Binding Rows}" Background="Transparent" BorderThickness="0">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="120" />
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"
                                   Foreground="{DynamicResource BrushTextPrimary}" FontSize="12"
                                   TextTrimming="CharacterEllipsis" />
                        <!-- 默认值提示 -->
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="11"
                                   Foreground="{DynamicResource BrushTextDim}" Margin="16,0,0,0">
                          <Run Text="默认：" />
                          <Run Text="{Binding DefaultHotKeyPlaceholder, Mode=OneWay}" />
                        </TextBlock>
                        <!-- 捕获控件 -->
                        <ctrl:HotkeyCaptureControl Grid.Column="2"
                                                   HotkeyText="{Binding CurrentHotkey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                   Margin="12,0,0,0"
                                                   VerticalAlignment="Center" />
                        <!-- 清除按钮：仅当已分配热键时显示 -->
                        <Button Grid.Column="3" Content="清除"
                                Command="{Binding ClearCommand}"
                                Visibility="{Binding HasHotkey, Converter={StaticResource BoolVis}}"
                                Style="{DynamicResource SmallButton}" Padding="10,4" FontSize="11"
                                Margin="8,0,0,0" VerticalAlignment="Center"
                                ToolTip="清除该功能的快捷键（置空，不再响应按键）" />
                        <!-- 冲突提示 -->
                        <TextBlock Grid.Column="4" VerticalAlignment="Center" Margin="12,0,0,0"
                                   FontSize="11" TextWrapping="Wrap" MaxWidth="200"
                                   Visibility="{Binding HasConflict, Converter={StaticResource BoolVis}}">
                          <Run Text="⚠ 与「" /><Run Text="{Binding ConflictWith, Mode=OneWay}" /><Run Text="」冲突" />
                        </TextBlock>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    <!-- 底部操作 -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button Content="恢复全部默认" Command="{Binding ResetAllCommand}"
              Style="{DynamicResource CompactButton}" Padding="14,6" FontSize="12" Margin="0,0,8,0" />
      <Button Content="保存" Command="{Binding SaveCommand}"
              Style="{DynamicResource PrimaryButton}" Padding="20,6" FontSize="13" FontWeight="SemiBold" />
    </StackPanel>
  </Grid>
</UserControl>
