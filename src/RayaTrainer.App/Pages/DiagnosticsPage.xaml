<UserControl x:Class="RayaTrainer.App.Pages.DiagnosticsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:RayaTrainer.App.Controls">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="0,0,0,18">
      <!-- Command header -->
      <Grid Margin="0,0,0,14">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock Text="连接检查与修复" FontSize="22" FontWeight="SemiBold"
                     Foreground="{DynamicResource BrushTextPrimary}" />
          <TextBlock Text="按顺序检查每一步；需要处理的项目会直接给出按钮。"
                     Margin="0,4,0,0" FontSize="12"
                     Foreground="{DynamicResource BrushTextSecondary}" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <Button Content="再检查一次" Command="{Binding RefreshCommand}"
                  Style="{DynamicResource CompactButton}" Margin="0,0,8,0" />
          <Button Content="打开技术报告" Command="{Binding OpenReportCommand}"
                  Style="{DynamicResource CompactButton}" Margin="0,0,8,0" />
          <Button Content="导出诊断包（给开发者）" Command="{Binding ExportCommand}"
                  Style="{DynamicResource PrimaryButton}" />
        </StackPanel>
      </Grid>

      <!-- Overall health -->
      <Border CornerRadius="8" Padding="16,13" Margin="0,0,0,14"
              BorderThickness="1">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BrushToolbarBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushCardBorder}" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding Health}" Value="Healthy">
                <Setter Property="BorderBrush" Value="{DynamicResource BrushSuccess}" />
              </DataTrigger>
              <DataTrigger Binding="{Binding Health}" Value="Attention">
                <Setter Property="BorderBrush" Value="{DynamicResource BrushWarning}" />
              </DataTrigger>
              <DataTrigger Binding="{Binding Health}" Value="Error">
                <Setter Property="BorderBrush" Value="{DynamicResource BrushError}" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <DockPanel>
          <TextBlock DockPanel.Dock="Right" Text="{Binding CapturedAtText, StringFormat=采集 {0}}"
                     FontFamily="Cascadia Mono, Consolas" FontSize="11"
                     Foreground="{DynamicResource BrushTextDim}" VerticalAlignment="Center" />
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="HEALTH " FontFamily="Cascadia Mono, Consolas" FontSize="13"
                       Foreground="{DynamicResource BrushTextDim}" VerticalAlignment="Center" />
            <TextBlock Text="{Binding HealthLabel}" FontFamily="Cascadia Mono, Consolas"
                       FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="4,0,16,0">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Foreground" Value="{DynamicResource BrushTextDim}" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Health}" Value="Healthy">
                      <Setter Property="Foreground" Value="{DynamicResource BrushSuccess}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Health}" Value="Attention">
                      <Setter Property="Foreground" Value="{DynamicResource BrushWarning}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Health}" Value="Error">
                      <Setter Property="Foreground" Value="{DynamicResource BrushError}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
            <TextBlock Text="{Binding Summary}" FontSize="13"
                       Foreground="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center"
                       TextWrapping="Wrap" />
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- Signature element: the actual runtime chain, not decorative steps. -->
      <ItemsControl ItemsSource="{Binding Stages}" Margin="0,0,0,14">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid Columns="6" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushCardBorder}" BorderThickness="1"
                    CornerRadius="6" Padding="10,9" Margin="0,0,8,0"
                    ToolTip="{Binding Guidance}">
              <Border.Style>
                <Style TargetType="Border">
                  <Setter Property="BorderBrush" Value="{DynamicResource BrushCardBorder}" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding State}" Value="Healthy">
                      <Setter Property="BorderBrush" Value="{DynamicResource BrushPrimary}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding State}" Value="Warning">
                      <Setter Property="BorderBrush" Value="{DynamicResource BrushWarning}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding State}" Value="Error">
                      <Setter Property="BorderBrush" Value="{DynamicResource BrushError}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <StackPanel>
                <TextBlock Text="{Binding TechnicalLabel}" FontFamily="Cascadia Mono, Consolas"
                           FontSize="9" Foreground="{DynamicResource BrushTextDim}" />
                <TextBlock Text="{Binding Label}" Margin="0,2,0,0"
                           FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}" />
                <TextBlock Text="{Binding StateLabel}" Margin="0,4,0,0" FontSize="10" FontWeight="SemiBold">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Foreground" Value="{DynamicResource BrushTextDim}" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding State}" Value="Healthy">
                          <Setter Property="Foreground" Value="{DynamicResource BrushSuccess}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding State}" Value="Warning">
                          <Setter Property="Foreground" Value="{DynamicResource BrushWarning}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding State}" Value="Error">
                          <Setter Property="Foreground" Value="{DynamicResource BrushError}" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding Summary}" Margin="0,5,0,0" FontSize="10"
                           Foreground="{DynamicResource BrushTextSecondary}"
                           TextWrapping="Wrap" MaxHeight="44" />
                <TextBlock Text="{Binding Guidance}" Margin="0,5,0,0" FontSize="10"
                           Foreground="{DynamicResource BrushTextDim}" TextWrapping="Wrap" />
                <Button Content="{Binding ActionLabel}" Command="{Binding ActionCommand}"
                        Visibility="{Binding HasAction, Converter={StaticResource BoolVis}}"
                        Style="{DynamicResource CompactButton}" Margin="0,8,0,0" Padding="8,4" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Layer 1: readable summaries -->
      <Grid Margin="0,0,0,14">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ctrl:ActionCard Header="当前目标" Margin="0,0,8,8">
          <TextBlock Text="{Binding TargetDetails}" TextWrapping="Wrap"
                     FontFamily="Cascadia Mono, Consolas" FontSize="11"
                     Foreground="{DynamicResource BrushTextSecondary}" />
        </ctrl:ActionCard>
        <ctrl:ActionCard Grid.Column="1" Header="连接与兼容性" Margin="8,0,0,8">
          <StackPanel>
            <TextBlock Text="{Binding AgentDetails}" TextWrapping="Wrap"
                       Foreground="{DynamicResource BrushTextSecondary}" />
            <TextBlock Text="{Binding SignatureDetails}" TextWrapping="Wrap" Margin="0,5,0,0"
                       Foreground="{DynamicResource BrushTextSecondary}" />
          </StackPanel>
        </ctrl:ActionCard>
        <ctrl:ActionCard Grid.Row="1" Header="功能组件" Margin="0,8,8,0">
          <TextBlock Text="{Binding PatchDetails}" TextWrapping="Wrap"
                     Foreground="{DynamicResource BrushTextSecondary}" />
        </ctrl:ActionCard>
        <ctrl:ActionCard Grid.Row="1" Grid.Column="1" Header="游戏状态" Margin="8,8,0,0">
          <TextBlock Text="{Binding GameDetails}" TextWrapping="Wrap"
                     FontFamily="Cascadia Mono, Consolas"
                     Foreground="{DynamicResource BrushTextSecondary}" />
        </ctrl:ActionCard>
      </Grid>

      <!-- LAA patch card -->
      <ctrl:ActionCard Header="4GB 内存标记 (LAA)" Margin="0,0,0,14"
                       IsExpanded="True">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel>
            <TextBlock Text="{Binding LaaSummary}" TextWrapping="Wrap"
                       Foreground="{DynamicResource BrushTextSecondary}" />
            <TextBlock Text="{Binding LaaModulePath}" TextWrapping="Wrap" Margin="0,4,0,0"
                       FontFamily="Cascadia Mono, Consolas" FontSize="10"
                       Foreground="{DynamicResource BrushTextDim}"
                       Visibility="{Binding LaaModulePath, Converter={StaticResource StringToVisibilityConverter}}" />
            <TextBlock Text="存在备份文件 (原文件名.Backup)" Margin="0,4,0,0"
                       Foreground="{DynamicResource BrushSuccess}" FontSize="10"
                       Visibility="{Binding HasLaaBackup, Converter={StaticResource BoolVis}}" />
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
            <Button Content="检查 LAA" Command="{Binding CheckLaaCommand}"
                    Style="{DynamicResource CompactButton}" Margin="0,0,8,0" />
            <Button Content="一键标记 LAA" Command="{Binding PatchLaaCommand}"
                    Style="{DynamicResource PrimaryButton}"
                    Visibility="{Binding ShowLaaPatchButton, Converter={StaticResource BoolVis}}" />
          </StackPanel>
        </Grid>
      </ctrl:ActionCard>

      <!-- Capability matrix -->
      <TextBlock Text="哪些功能可以使用" FontSize="16" FontWeight="SemiBold"
                 Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,8" />
      <ItemsControl ItemsSource="{Binding CapabilityGroups}" Margin="0,0,0,14">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <ctrl:ActionCard Header="{Binding Name}" IsExpanded="False" Margin="0,0,0,8">
              <ItemsControl ItemsSource="{Binding Capabilities}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid Margin="0,4">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="{Binding DisplayName}" ToolTip="{Binding Reason}"
                                 Foreground="{DynamicResource BrushTextPrimary}" />
                      <Border Grid.Column="1" CornerRadius="8" Padding="7,2"
                              Background="{DynamicResource BrushFactionImperialSoft}"
                              ToolTip="{Binding Reason}">
                        <TextBlock FontSize="10" FontWeight="SemiBold">
                          <TextBlock.Style>
                            <Style TargetType="TextBlock">
                              <Setter Property="Text" Value="等待" />
                              <Setter Property="Foreground" Value="{DynamicResource BrushWarning}" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding State}" Value="Ready">
                                  <Setter Property="Text" Value="就绪" />
                                  <Setter Property="Foreground" Value="{DynamicResource BrushSuccess}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding State}" Value="Unavailable">
                                  <Setter Property="Text" Value="不可用" />
                                  <Setter Property="Foreground" Value="{DynamicResource BrushError}" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>
                      </Border>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ctrl:ActionCard>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Layer 2: event stream -->
      <ctrl:ActionCard Header="本次运行记录" Margin="0,0,0,10">
        <ItemsControl ItemsSource="{Binding Events}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="74" />
                  <ColumnDefinition Width="90" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Timestamp, StringFormat=HH:mm:ss}"
                           FontFamily="Cascadia Mono, Consolas" FontSize="10"
                           Foreground="{DynamicResource BrushTextDim}" />
                <TextBlock Grid.Column="1" Text="{Binding Code}"
                           FontFamily="Cascadia Mono, Consolas" FontSize="10"
                           Foreground="{DynamicResource BrushPrimary}" />
                <TextBlock Grid.Column="2" Text="{Binding Message}" ToolTip="{Binding Detail}"
                           TextWrapping="Wrap" Foreground="{DynamicResource BrushTextSecondary}" />
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ctrl:ActionCard>

      <!-- Layer 3: raw technical values, collapsed by default. -->
      <Expander Header="技术详情" IsExpanded="False">
        <TextBox IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                 FontFamily="Cascadia Mono, Consolas" FontSize="10" MinHeight="90"
                 Text="{Binding TechnicalDetails, Mode=OneWay}" />
      </Expander>
    </StackPanel>
  </ScrollViewer>
</UserControl>
