<UserControl x:Class="RayaTrainer.App.Pages.SecretProtocolPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:RayaTrainer.App.Controls">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="0,0,0,16">

      <!-- 协议与技能开关 -->
      <Border Style="{DynamicResource ActionCardBorder}">
        <StackPanel>
          <TextBlock Text="协议与技能开关" FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,14" />
          <ItemsControl ItemsSource="{Binding SecretProtocolToggles}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Margin="0,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{Binding DisplayName}"
                             ToolTip="{Binding HelpText}"
                             ToolTipService.InitialShowDelay="250"
                             ToolTipService.ShowDuration="12000"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource BrushTextPrimary}" FontSize="13" />
                  <ctrl:KeyBadge Grid.Column="1" Content="{Binding HotkeyDisplay}"
                                 ToolTip="右键修改快捷键"
                                 VerticalAlignment="Center" Margin="10,0,0,0" MinWidth="28">
                    <ctrl:KeyBadge.ContextMenu>
                      <ContextMenu>
                        <MenuItem Header="修改快捷键…"
                                  Command="{Binding PlacementTarget.DataContext.OpenHotkeySettingsCommand, RelativeSource={RelativeSource Self}}" />
                        <MenuItem Header="清除快捷键"
                                  Command="{Binding PlacementTarget.DataContext.ClearHotkeyCommand, RelativeSource={RelativeSource Self}}" />
                      </ContextMenu>
                    </ctrl:KeyBadge.ContextMenu>
                  </ctrl:KeyBadge>
                  <ctrl:ToggleSwitch Grid.Column="2"
                                     IsChecked="{Binding IsFeatureEnabled, Mode=OneWay}"
                                     Command="{Binding Command}"
                                     ToolTip="{Binding HelpText}"
                                     VerticalAlignment="Center"
                                     Margin="14,0,0,0" />
                  <TextBlock Grid.Column="3" Text="{Binding Status}" ToolTip="{Binding HelpText}"
                             VerticalAlignment="Center" Margin="14,0,0,0"
                             FontSize="12" MinWidth="50" TextAlignment="Right">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource BrushTextDim}" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsFeatureEnabled}" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource BrushSuccess}" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- 协议授予 -->
      <Border Style="{DynamicResource ActionCardBorder}">
        <StackPanel>
          <TextBlock Text="协议授予" FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,14" />
          <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="150" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="150" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="150" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="协议名" VerticalAlignment="Center"
                       Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,10,0" FontSize="13" />
            <TextBox Grid.Column="1"
                     Text="{Binding SecretProtocolNameText, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="{Binding SecretProtocolNameHelpText}" />
            <TextBlock Grid.Column="2" Text="PlayerTech ID" VerticalAlignment="Center"
                       Foreground="{DynamicResource BrushTextSecondary}" Margin="14,0,10,0" FontSize="13" />
            <TextBox Grid.Column="3"
                     Text="{Binding SecretProtocolPlayerTechIdText, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="{Binding SecretProtocolPlayerTechIdHelpText}" />
            <TextBlock Grid.Column="4" Text="Upgrade ID" VerticalAlignment="Center"
                       Foreground="{DynamicResource BrushTextSecondary}" Margin="14,0,10,0" FontSize="13" />
            <TextBox Grid.Column="5"
                     Text="{Binding SecretProtocolUpgradeIdText, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="{Binding SecretProtocolUpgradeIdHelpText}" />
          </Grid>
          <StackPanel Orientation="Horizontal">
            <Button Content="协议列表" Command="{Binding OpenSecretProtocolPickerCommand}"
                    ToolTip="{Binding OpenSecretProtocolPickerHelpText}" />
            <Button Content="当前入队" Command="{Binding AddCurrentSecretProtocolToQueueCommand}"
                    ToolTip="{Binding AddCurrentSecretProtocolToQueueHelpText}" Margin="10,0,0,0" />
            <Button Content="授予当前" Command="{Binding GrantCurrentSecretProtocolCommand}"
                    ToolTip="{Binding GrantCurrentSecretProtocolHelpText}"
                    Style="{DynamicResource PrimaryButton}" Margin="10,0,0,0" />
            <Button Content="授予选中建筑" Command="{Binding GrantSelectedObjectUpgradeCommand}"
                    ToolTip="{Binding GrantSelectedObjectUpgradeHelpText}" Margin="10,0,0,0" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- 预设管理 -->
      <Border Style="{DynamicResource ActionCardBorder}">
        <StackPanel>
          <TextBlock Text="预设管理" FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,14" />
          <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="140" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="180" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="预设名" VerticalAlignment="Center"
                       Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,10,0" FontSize="13" />
            <TextBox Grid.Column="1"
                     Text="{Binding SecretProtocolPresetNameText, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="{Binding SecretProtocolPresetNameHelpText}" />
            <TextBlock Grid.Column="2" Text="预设" VerticalAlignment="Center"
                       Foreground="{DynamicResource BrushTextSecondary}" Margin="14,0,10,0" FontSize="13" />
            <ComboBox Grid.Column="3"
                      ItemsSource="{Binding SecretProtocolPresets}"
                      SelectedItem="{Binding SelectedSecretProtocolPreset}"
                      DisplayMemberPath="Name"
                      ToolTip="{Binding SecretProtocolPresetHelpText}" />
            <Button Grid.Column="4" Content="保存预设"
                    Command="{Binding SaveSecretProtocolPresetCommand}"
                    ToolTip="{Binding SaveSecretProtocolPresetHelpText}" Margin="10,0,0,0" />
            <Button Grid.Column="5" Content="应用预设"
                    Command="{Binding ApplySecretProtocolPresetCommand}"
                    ToolTip="{Binding ApplySecretProtocolPresetHelpText}" Margin="10,0,0,0" />
            <Button Grid.Column="6" Content="追加预设"
                    Command="{Binding AppendSecretProtocolPresetCommand}"
                    ToolTip="{Binding AppendSecretProtocolPresetHelpText}" Margin="10,0,0,0" />
          </Grid>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
            <Button Content="授予列表" Command="{Binding GrantSecretProtocolQueueCommand}"
                    ToolTip="{Binding GrantSecretProtocolQueueHelpText}"
                    Style="{DynamicResource PrimaryButton}" />
            <Button Content="清空列表" Command="{Binding ClearSecretProtocolQueueCommand}"
                    ToolTip="{Binding ClearSecretProtocolQueueHelpText}" Margin="10,0,0,0"
                    Style="{DynamicResource DangerButton}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- 授予队列 -->
      <Border Style="{DynamicResource ActionCardBorder}">
        <StackPanel>
          <TextBlock Text="授予队列" FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,14" />
          <ItemsControl ItemsSource="{Binding SecretProtocolQueue}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Margin="0,4">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <Border CornerRadius="4" Padding="6,2" VerticalAlignment="Center" Margin="0,0,0,0">
                    <Border.Style>
                      <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding Faction}" Value="苏联">
                            <Setter Property="Background" Value="{DynamicResource BrushFactionSovietSoft}" />
                          </DataTrigger>
                          <DataTrigger Binding="{Binding Faction}" Value="盟军">
                            <Setter Property="Background" Value="{DynamicResource BrushFactionAlliedSoft}" />
                          </DataTrigger>
                          <DataTrigger Binding="{Binding Faction}" Value="升阳">
                            <Setter Property="Background" Value="{DynamicResource BrushFactionImperialSoft}" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding Faction}" FontSize="11" FontFamily="Cascadia Mono, Consolas">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Foreground" Value="{DynamicResource BrushTextSecondary}" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding Faction}" Value="苏联">
                              <Setter Property="Foreground" Value="{DynamicResource BrushFactionSoviet}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Faction}" Value="盟军">
                              <Setter Property="Foreground" Value="{DynamicResource BrushPrimary}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Faction}" Value="升阳">
                              <Setter Property="Foreground" Value="{DynamicResource BrushFactionImperial}" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </Border>
                  <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                             Foreground="{DynamicResource BrushTextPrimary}" FontSize="13" />
                  <TextBlock Grid.Column="2" Text="{Binding PlayerTechIdText}" VerticalAlignment="Center"
                             Foreground="{DynamicResource BrushTextSecondary}" FontSize="12"
                             FontFamily="Cascadia Mono, Consolas, Courier New" />
                  <TextBlock Grid.Column="3" Text="{Binding UpgradeText}" VerticalAlignment="Center"
                             Foreground="{DynamicResource BrushTextSecondary}" FontSize="12" />
                  <TextBlock Grid.Column="4" Text="{Binding Status}" VerticalAlignment="Center"
                             Foreground="{DynamicResource BrushTextDim}" FontSize="12" />
                  <TextBlock Grid.Column="5" Text="{Binding Message}" VerticalAlignment="Center"
                             Foreground="{DynamicResource BrushTextDim}" FontSize="12" />
                  <Button Grid.Column="6" Content="移除" Command="{Binding RemoveCommand}"
                          ToolTip="{Binding RemoveQueueItemHelpText}"
                          Style="{DynamicResource SmallButton}" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- 名称转哈希 -->
      <Border Style="{DynamicResource ActionCardBorder}">
        <StackPanel>
          <TextBlock Text="名称转哈希" FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,14" />
          <TextBlock Foreground="{DynamicResource BrushTextSecondary}" FontSize="12" TextWrapping="Wrap"
                     Margin="0,0,0,14"
                     Text="输入 PlayerTech_ 或 Upgrade_ 名称后计算 RA3 哈希值。PlayerTech 前缀的名称写入 PlayerTech ID，Upgrade_ 前缀的写入 Upgrade ID。" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="名称" VerticalAlignment="Center"
                       Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,10,0" FontSize="13" />
            <TextBox Grid.Column="1"
                     Text="{Binding SecretProtocolHashSourceText, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="{Binding SecretProtocolHashSourceHelpText}" />
            <Button Grid.Column="2" Content="计算哈希"
                    Command="{Binding HashSecretProtocolSourceCommand}"
                    ToolTip="{Binding SecretProtocolHashSourceHelpText}"
                    Style="{DynamicResource PrimaryButton}" Margin="10,0,0,0" />
          </Grid>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
