<UserControl x:Class="RayaTrainer.App.Pages.ToolsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="0,0,0,16">

      <!-- 手机遥控 -->
      <Border Style="{DynamicResource ActionCardBorder}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,18,0">
              <TextBlock Text="手机遥控" FontSize="14" FontWeight="SemiBold"
                         Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,14" />
              <TextBlock Foreground="{DynamicResource BrushTextSecondary}" FontSize="12" TextWrapping="Wrap"
                         Margin="0,0,0,14"
                         Text="生成当前电脑的局域网遥控页面地址。手机扫码打开后，电脑端仍会弹出设备配对确认。" />
              <!-- 网络地址选择 -->
              <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="网络地址" VerticalAlignment="Center"
                           Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,10,0" FontSize="13" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding MobileRemote.AvailableAddresses}"
                          SelectedItem="{Binding MobileRemote.SelectedAddress}"
                          DisplayMemberPath="DisplayName"
                          MinHeight="28" />
              </Grid>
              <!-- 链接与生成 -->
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="链接" VerticalAlignment="Center"
                           Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,10,0" FontSize="13" />
                <TextBox Grid.Column="1"
                         Text="{Binding MobileRemote.RemoteUrl, Mode=OneWay}"
                         IsReadOnly="True"
                         ToolTip="{Binding MobileRemote.GenerateQrCodeHelpText}" />
                <Button Grid.Column="2" Content="生成二维码"
                        Command="{Binding MobileRemote.GenerateQrCodeCommand}"
                        ToolTip="{Binding MobileRemote.GenerateQrCodeHelpText}"
                        Style="{DynamicResource PrimaryButton}" Margin="10,0,0,0" />
              </Grid>
            </StackPanel>

          <Border Grid.Column="1"
                  Width="164" Height="164"
                  Background="White"
                  BorderBrush="{DynamicResource BrushCardBorder}"
                  BorderThickness="1"
                  CornerRadius="6"
                  Padding="8">
            <Image Source="{Binding MobileRemote.QrCodeImage}"
                   Stretch="Uniform"
                   SnapsToDevicePixels="True" />
          </Border>
        </Grid>
      </Border>

      <!-- 版本更新 -->
      <Border Style="{DynamicResource ActionCardBorder}">
        <StackPanel>
          <TextBlock Text="版本更新" FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,14" />
          <TextBlock Text="{Binding CurrentVersionText}" Foreground="{DynamicResource BrushTextSecondary}"
                     FontSize="12" TextWrapping="Wrap" Margin="0,0,0,14" />
          <Button Content="检查更新"
                  Command="{Binding CheckForUpdatesCommand}"
                  ToolTip="{Binding CheckForUpdatesHelpText}"
                  Style="{DynamicResource PrimaryButton}"
                  HorizontalAlignment="Left" />
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
