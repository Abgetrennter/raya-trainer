<Window x:Class="RayaTrainer.App.Views.ReinforcementUnitPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择增援单位"
        Height="640"
        Width="980"
        MinHeight="480"
        MinWidth="840"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BrushWindowBackground}">
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Top">
      <Grid Margin="0,0,0,10">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid Margin="0,0,10,0">
          <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                   ToolTip="{Binding SearchHelpText}" />
          <TextBlock Text="{Binding SearchPlaceholderText}"
                     Foreground="{DynamicResource BrushTextDisabled}"
                     Margin="10,0,0,0"
                     VerticalAlignment="Center"
                     IsHitTestVisible="False">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding SearchText}" Value="">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </Grid>
        <Button Grid.Column="1" Content="导入文件"
                Command="{Binding ImportCommand}" ToolTip="{Binding ImportHelpText}" Margin="0,0,8,0" />
        <Button Grid.Column="2" Content="确认"
                Command="{Binding ConfirmCommand}" ToolTip="{Binding ConfirmHelpText}"
                Style="{DynamicResource PrimaryButton}" Margin="0,0,8,0" />
        <Button Grid.Column="3" Content="取消"
                Command="{Binding CancelCommand}" ToolTip="{Binding CancelHelpText}" />
      </Grid>
      <Border Background="{DynamicResource BrushCardBackground}"
              BorderBrush="{DynamicResource BrushCardBorder}"
              BorderThickness="1"
              Padding="10"
              CornerRadius="6"
              Margin="0,0,0,8">
        <TextBlock Foreground="{DynamicResource BrushTextSecondary}"
                   TextWrapping="Wrap" FontSize="11"
                   Text="导入格式：每行一条，使用英文逗号或 Tab 分隔：模组,阵营,单位代码,单位名称。示例：起义时刻,盟军,EA8F676B,冷冻兵团。单位代码支持 0x 前缀有无和大小写混用；导入后会保存到 RayaTrainer.reinforcements.txt，下次启动自动加载。" />
      </Border>
      <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,4" FontSize="12" />
    </StackPanel>

    <TabControl ItemsSource="{Binding Mods}"
                SelectedItem="{Binding SelectedMod, Mode=TwoWay}"
                Background="{DynamicResource BrushCardBackground}"
                Foreground="{DynamicResource BrushTextPrimary}">
      <TabControl.ItemTemplate>
        <DataTemplate>
          <TextBlock Text="{Binding Name}" />
        </DataTemplate>
      </TabControl.ItemTemplate>
      <TabControl.ContentTemplate>
        <DataTemplate>
          <TabControl ItemsSource="{Binding DataContext.Factions, RelativeSource={RelativeSource AncestorType=Window}}"
                      SelectedItem="{Binding DataContext.SelectedFaction, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                      Margin="0,8,0,0">
            <TabControl.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Name}" />
              </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
              <DataTemplate>
                <ListView ItemsSource="{Binding DataContext.FilteredUnits, RelativeSource={RelativeSource AncestorType=Window}}"
                          SelectedItem="{Binding DataContext.SelectedUnit, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                          BorderBrush="{DynamicResource BrushCardBorder}"
                          BorderThickness="1"
                          Background="{DynamicResource BrushCardBackground}"
                          Foreground="{DynamicResource BrushTextPrimary}"
                          Margin="0,8,0,0">
                  <ListView.ItemContainerStyle>
                    <Style TargetType="{x:Type ListViewItem}">
                      <EventSetter Event="PreviewMouseLeftButtonUp" Handler="OnUnitItemPreviewMouseLeftButtonUp" />
                    </Style>
                  </ListView.ItemContainerStyle>
                  <ListView.View>
                    <GridView>
                      <GridViewColumn Header="代码" Width="140" DisplayMemberBinding="{Binding CodeText}" />
                      <GridViewColumn Header="名称" Width="220" DisplayMemberBinding="{Binding Name}" />
                      <GridViewColumn Header="ID" Width="260" DisplayMemberBinding="{Binding SourceId}" />
                      <GridViewColumn Header="阵营" Width="100" DisplayMemberBinding="{Binding Faction}" />
                      <GridViewColumn Header="模组" Width="120" DisplayMemberBinding="{Binding Mod}" />
                    </GridView>
                  </ListView.View>
                </ListView>
              </DataTemplate>
            </TabControl.ContentTemplate>
          </TabControl>
        </DataTemplate>
      </TabControl.ContentTemplate>
    </TabControl>
  </DockPanel>
</Window>
