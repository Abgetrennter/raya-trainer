<Window x:Class="RayaTrainer.App.Views.SecretProtocolPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择秘密协议"
        Height="640"
        Width="900"
        MinHeight="480"
        MinWidth="760"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BrushWindowBackground}">
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Top">
      <Grid Margin="0,0,0,10">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource BrushTextSecondary}" VerticalAlignment="Center" FontSize="12" />
        <Button Grid.Column="1" Content="导入文件"
                Command="{Binding ImportCommand}" ToolTip="{Binding ImportHelpText}" Margin="0,0,8,0" />
        <Button Grid.Column="2" Content="确认"
                Command="{Binding ConfirmCommand}" ToolTip="{Binding ConfirmHelpText}"
                Style="{DynamicResource PrimaryButton}" Margin="0,0,8,0" />
        <Button Grid.Column="3" Content="取消"
                Command="{Binding CancelCommand}" ToolTip="{Binding CancelHelpText}" />
      </Grid>
      <Border Background="{DynamicResource BrushCardBackground}"
              BorderBrush="{DynamicResource BrushCardBorder}"
              BorderThickness="1"
              Padding="10"
              CornerRadius="6"
              Margin="0,0,0,8">
        <TextBlock Foreground="{DynamicResource BrushTextSecondary}"
                   TextWrapping="Wrap" FontSize="11"
                   Text="选择协议后点确认，会把 PlayerTech/Upgrade ID 带回主窗口授予栏。仅 SpecialPower 的条目作为参考显示，缺少 PlayerTech 或 Upgrade 时不能直接授予。" />
      </Border>
    </StackPanel>

    <TabControl ItemsSource="{Binding Mods}"
                SelectedItem="{Binding SelectedMod, Mode=TwoWay}"
                Background="{DynamicResource BrushCardBackground}"
                Foreground="{DynamicResource BrushTextPrimary}">
      <TabControl.ItemTemplate>
        <DataTemplate>
          <TextBlock Text="{Binding Name}" />
        </DataTemplate>
      </TabControl.ItemTemplate>
      <TabControl.ContentTemplate>
        <DataTemplate>
          <TabControl ItemsSource="{Binding DataContext.Factions, RelativeSource={RelativeSource AncestorType=Window}}"
                      SelectedItem="{Binding DataContext.SelectedFaction, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                      Margin="0,8,0,0">
            <TabControl.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Name}" />
              </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
              <DataTemplate>
                <ListView ItemsSource="{Binding DataContext.FilteredProtocols, RelativeSource={RelativeSource AncestorType=Window}}"
                          SelectedItem="{Binding DataContext.SelectedProtocolOption, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                          BorderBrush="{DynamicResource BrushCardBorder}"
                          BorderThickness="1"
                          Background="{DynamicResource BrushCardBackground}"
                          Foreground="{DynamicResource BrushTextPrimary}"
                          Margin="0,8,0,0">
                  <ListView.View>
                    <GridView>
                      <GridViewColumn Header="协议" Width="160" DisplayMemberBinding="{Binding Name}" />
                      <GridViewColumn Header="阵营" Width="90" DisplayMemberBinding="{Binding Faction}" />
                      <GridViewColumn Header="PlayerTech" Width="120" DisplayMemberBinding="{Binding PlayerTechIdText}" />
                      <GridViewColumn Header="Upgrade" Width="300" DisplayMemberBinding="{Binding UpgradeText}" />
                      <GridViewColumn Header="状态" Width="80" DisplayMemberBinding="{Binding GrantStateText}" />
                    </GridView>
                  </ListView.View>
                </ListView>
              </DataTemplate>
            </TabControl.ContentTemplate>
          </TabControl>
        </DataTemplate>
      </TabControl.ContentTemplate>
    </TabControl>
  </DockPanel>
</Window>
